

<ul class="list-unstyled list-social p-0{% if class %} {{ class}}{% endif %}" role="list">
  {%- if settings.social_instagram_link != blank -%}
    <li class="list-social__item flex">
      <a target="_blank" href="{{ settings.social_instagram_link }}" class="link list-social__link link--text list-menu__item  list-menu__item--link  body-text">
        <span class="social-links">{{ 'general.social.links.instagram' | t }}</span>
      </a>
    </li>
  {%- endif -%}
