{{ 'icon-with-text-section.css' | asset_url | stylesheet_tag }}
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 769px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }
  #icon-with-text-section-{{ section.id }}{
    --color-foreground: {{ section.settings.text_color.red }}, {{ section.settings.text_color.green }},{{ section.settings.text_color.blue }};
    --color-background: {{ section.settings.background_color.red }}, {{ section.settings.background_color.green }},{{ section.settings.background_color.blue }};
    --color-link : var(--color-foreground);
    --image-radius: {{  section.settings.image_radius }}%;
  }
{%- endstyle -%}
<section id="icon-with-text-section-{{ section.id }}" class="icon-with-text-section section-{{ section.id }}-padding ">
  {% if section.settings.heading_text != blank %}
    <div class="heading-wrapper page-width flex">
        {%  if section.settings.heading_text != blank %}
          <div class="section-heading heading-extra-large-v2 small-heading-extra-large-v2">
            {{ section.settings.heading_text }}
          </div>
        {%  endif %}
    </div>
  {% endif %}
  <icon-with-text-section>
    <div class="swiper js-icon-with-text-section">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% if block.settings.icon != blank %}
            <div class="swiper-slide">
              {% if block.settings.link != blank %}
                <a class="icon-with-text-link link text-decoration-none w-100 h-100" href="{{ block.settings.link.url }}" >
              {% endif %}
                <div class="collection-media-wrapper h-100 flex direction-column">
                  <div class="collection-media relative flex flex-1 align-item-center justify-center" style="border-radius: {{ section.settings.image_radius }}%">
                      {{ block.settings.icon  | image_url: width: 2500, height:3500 | image_tag  }}
                  </div>
                  {% if block.settings.text != blank %}
                    <div class="collection-bottom-text heading-text-large-thin small-heading-text-large-thin center"> 
                      {{ block.settings.text }}
                    </div>
                  {% endif %}
                </div>
              {% if block.settings.link != blank %}
                  </a>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </icon-with-text-section>


</section>

{% schema %}
  {
    "name": "Icon With text",
    "tag": "section",
    "settings": [
      //{
      //  "type": "color",
        //"id": "background_color",
        //"label": "Background Color",
        //"default": "#F5EFE6"
      //},
      {
        "type": "color",
        "id": "text_color",
        "label": "Text Color",
        "default": "#000000"
      },
      {
        "type": "text",
        "id": "heading_text",
        "label": "Heading"
      },
      {
        "type": "range",
        "id": "image_radius",
        "label": "Radius For image",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "%",
        "default": 0
      },
      {
        "type": "header",
        "content": "Padding - Desktop"
      },
      {
        "type": "range",
        "id": "padding_top_desktop",
        "label": "Padding Top - Desktop",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default": 35
      },
      {
        "type": "range",
        "id": "padding_bottom_desktop",
        "label": "Padding Bottom - Desktop",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default": 35
      },
      {
        "type": "header",
        "content": "Padding - Mobile"
      },
      {
        "type": "range",
        "id": "padding_top_mobile",
        "label": "Padding Top - Mobile",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default": 15
      },
      {
        "type": "range",
        "id": "padding_bottom_mobile",
        "label": "Padding Bottom - Mobile",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default": 15
      }
    ],
    "blocks": [
      {
        "type": "SLide",
        "name": "Slide",
        "settings": [
          {
            "type": "image_picker",
            "id": "icon",
            "label": "Icon"
          },
           {
            "type": "text",
            "id": "text",
            "label": "Text",
          },
          {
            "type": "url",
            "id": "link",
            "label": "LInk"
          }
        ]
      },
    ],
    "presets": [
      {
        "name": "Icon With text",
      }
    ]
  }
{% endschema %}