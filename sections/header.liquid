{% if section.settings.header_with_search_layout == true %}
    <link rel="stylesheet" href="{{ 'inline-searchbar-layout.css' | asset_url }}" media="print" onload="this.media='all'">
{% endif %}
<style>
  .section-header{
    --color-foreground: {{ section.settings.text_color.red }},{{ section.settings.text_color.green }},{{ section.settings.text_color.blue }};
    --color-background: {{ section.settings.color_background.red }},{{ section.settings.color_background.green }},{{ section.settings.color_background.blue }};
    --color-transprent: {{ section.settings.color_transprent.red }},{{ section.settings.color_transprent.green }},{{ section.settings.color_transprent.blue }};
  }
header{
    --color-menu-text:{{ section.settings.color_menu_text.red }},{{ section.settings.color_menu_text.green }},{{ section.settings.color_menu_text.blue }};
    --color-menu-background: {{ section.settings.color_background_menu.red }},{{ section.settings.color_background_menu.green }},{{ section.settings.color_background_menu.blue }};
      --color-foreground: var(--color-menu-text);
       --color-background: var(--color-menu-background);
       --header-logo-color: {{ section.settings.logo_text_color }};
  }
  header.has-inline-searchbar-layout .inline-searchbar-menu-layout{
     --color-mega-menu-text:{{ section.settings.color_menu_text.red }},{{ section.settings.color_menu_text.green }},{{ section.settings.color_menu_text.blue }};
    --color-mega-menu-background: {{ section.settings.color_background_menu.red }},{{ section.settings.color_background_menu.green }},{{ section.settings.color_background_menu.blue }};
    --color-menu-text:{{ section.settings.color_menu_bottom_text.red }},{{ section.settings.color_menu_bottom_text.green }},{{ section.settings.color_menu_bottom_text.blue }};
    --color-menu-background: {{ section.settings.color_background_bottom_menu.red }},{{ section.settings.color_background_bottom_menu.green }},{{ section.settings.color_background_bottom_menu.blue }};
     --color-foreground: var(--color-menu-text);
       --color-background: var(--color-menu-background);
  }

  header.has-inline-searchbar-layout {
    --color-mega-menu-text:{{ section.settings.color_menu_text.red }},{{ section.settings.color_menu_text.green }},{{ section.settings.color_menu_text.blue }};
    --color-mega-menu-background: {{ section.settings.color_background_menu.red }},{{ section.settings.color_background_menu.green }},{{ section.settings.color_background_menu.blue }};
  }
  header-drawer {
    justify-self: start;
    {% comment %} margin-left: -1.2rem; {% endcomment %}
  }


  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 990px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
    width: 100%;
    justify-content: center;
    row-gap: .5rem;
    column-gap: 2.5rem;
    align-items: center;
  }


  .list-menu__item {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 0;
  }

  @media screen and (min-width: 769px) {
    .list-menu__item--link {
      padding-bottom: 1rem;
      padding-top: 0;
    }
