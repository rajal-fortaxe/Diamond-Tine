{{ 'text-with-content.css' | asset_url | stylesheet_tag }}
{%- style -%}
   #text-with-content-{{ section.id }} .text-with-content-item {
     background: {{ section.settings.tile_background_color }};
   }
   #text-with-content-{{ section.id }} .text-with-content-wrapper{
     grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
   }
  .section-{{ section.id }}-padding {
     padding-top: {{ section.settings.padding_top_mobile }}px;
     padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
   }

   @media screen and (min-width: 769px) {
     .section-{{ section.id }}-padding {
       padding-top: {{ section.settings.padding_top_desktop }}px;
       padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
     }
   }
{%- endstyle -%}
<section id="text-with-content-{{ section.id }}" class="text-with-content section-{{ section.id }}-padding">
  {% if section.settings.heading != blank %}
    <div
      class="section-heading heading-text-large-thin page-width center"
      style="color: {{ section.settings.heading_text_color  }}"
    >
      {{ section.settings.heading }}
    </div>
  {% endif %}

  <text-with-content>
    <div class="text-with-content-wrapper relative">
      <div class="swiper js-text-with-content">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            {% if block.settings.heading != blank or block.settings.description != blank %}
              <div class="swiper-slide">
                <div class="text-with-content-item">
                  {% if block.settings.heading != blank %}
                    <div class="text-with-content__heading heading-text-large-thin" style="color: {{ section.settings.text_color }}">
                      {{ block.settings.heading }}
                    </div>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <div class="text-with-content__description body-text" style="color: {{ section.settings.text_color }}">
                      {{ block.settings.description }}
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </text-with-content>
</section>

{% schema %}
{
  "name": "Two Image Grid",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    //{
    // "type": "color",
    //"id": "background_color",
    //"label": "Background Color",
    //},
    {
      "type": "color",
      "id": "heading_text_color",
      "label": "Heading Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "tile_background_color",
      "label": "Tile Background Color",
      "default": "#FFF8EE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "header",
      "content": "Padding - Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top - Desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 35
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom - Desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 35
    },
    {
      "type": "header",
      "content": "Padding - Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top - Mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom - Mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 25
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Text With Content"
    }
  ]
}
{% endschema %}
