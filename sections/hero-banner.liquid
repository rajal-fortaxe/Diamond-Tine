      "id": "link_text",
      "label": "Link Text"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link",
      "info": "This will apply to the banner when the heading, subheading, and link text are all blank."
    },
    {
      "type": "select",
      "id": "button_type",
      "label": "Button Type",
      "default": "outline",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "outline",
          "label": "Outline"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Align",
      "default": "bottom-left",
      "options": [
        {
          "value": "center-left",
          "label": "Center Left"
        },
        {
          "value": "center-center",
          "label": "Center"
        },
        {
          "value": "center-right",
          "label": "Center Right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom Left"
        },
        {
          "value": "bottom-center",
          "label": "Bottom Center"
        },
        {
          "value": "bottom-right",
          "label": "Bottom Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section Height - Desktop",
      "default": "auto",
      "options": [
        {
            "label": "Auto",
          "value": "auto"
        },
        {
          "label": "450px",
          "value": "450px"
        },
        {
          "label": "550px",
          "value": "550px"
        },
        {
