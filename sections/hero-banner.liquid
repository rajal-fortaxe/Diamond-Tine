{{ 'hero--banner.css' | asset_url | stylesheet_tag }}
{%- style -%}
 
  {% if section.settings.mobile_height != "auto" %}
     {% assign mobile_aspect_ratio = section.settings.mobile_height | remove: "px" | times: 1 %}
          .video-banner-{{ section.id }} video,
          .video-banner-{{ section.id }} img{
                height: {{  section.settings.mobile_height }};
                overflow: hidden;
                 aspect-ratio: 375/{{ mobile_aspect_ratio }};
          }
    {% endif %}
  @media only screen and (min-width: 769px) {
  
    {% if section.settings.section_height != "auto" %}
      {% assign desktop_aspect_ratio = section.settings.section_height | remove: "px" | times: 1 %}
          .video-banner-{{ section.id }} video,
          .video-banner-{{ section.id }} img {
                /* height: {{  section.settings.section_height }} */
                aspect-ratio: 1440/{{ desktop_aspect_ratio }};
                overflow: hidden;
          }
    {% endif %}
  }

  .video-banner-{{ section.id }} {
    color: {{ section.settings.text_color }};
  }
  .video-banner-{{ section.id }} .button {
   color: {{ section.settings.button_color }};
   background: {{ section.settings.button_background_color }};
  }
  .video-banner-{{ section.id }} .button--secondary{
    background: transparent;
    color: {{ section.settings.button_color }};
    border: 1px solid;
  }

{%- endstyle -%}
{% liquid
    assign banner_link = false
    assign has_only_button  = false
   if  section.settings.title == blank and section.settings.subheading == blank and section.settings.link != blank and section.settings.link_text == blank
      assign banner_link = true
   endif

   if  section.settings.title == blank and section.settings.subheading == blank and section.settings.link != blank and section.settings.link_text != blank
      assign has_only_button = true
   endif

%}

<section class="video-banner video-banner-{{ section.id }} scroll-trigger animate--slide-in  {%  if section.index == 1 and section.settings.enable_tranprent_header == true %} transprent-header{%  endif %}">
    <div class="video-banner-wrapper {% if section.settings.ebable_spacing == true %} has-spacing{%  endif %}">
        {% if section.settings.video_desktop != blank or section.settings.desktop_image != blank %}
          {% if banner_link == true %}
            <a href="{{ section.settings.link }}"> 
          {%  endif %}
            <div class="video-banner-media flex">
                
                {%  render 'banner-image-video', main_section: section %}
            </div>
             {% if banner_link == true %}
              </a>
              {%  endif %}
        {% endif %}
        {% if has_only_button == true %}
            <div class="video-banner-content page-width content-align-bottom-right">
                 <a href='{{ section.settings.link }}' class="flex video-content-arrow__button body-text-small small-body-text-small">
                  {{ section.settings.link_text }}
                   <span class="flex arrow-link">{% render 'icons', icon: 'button-arrow' %}</span>
                </a>
            </div>
        {%  else %}
          {%  if  section.settings.title != blank or section.settings.description != blank or section.settings.subheading != blank or  section.settings.link != blank and section.settings.link_text != blank %}
              <div class="video-banner-content page-width content-align-{{ section.settings.text_align }}">
                  <div class="video-banner-content__inner-wrapper">
                  {%- if section.settings.title != blank -%}
                      <div class="video-content__heading heading-extra-large small-heading-extra-large heading-text-large-thin">{{ section.settings.title }}</div>
                  {%  endif %}
                  {%- if section.settings.subheading != blank -%}
                      <div class="video-content__subheading heading-text-small-thin">{{ section.settings.subheading }}</div>
                  {%  endif %}
                  {%- if section.settings.description != blank -%}
                      <div class="video-content__description boody-text">{{ section.settings.description }}</div>
                  {%  endif %}
                  {%- if section.settings.link != blank and section.settings.link_text != blank -%}
                      <a href='{{ section.settings.link }}' class="video-content__button button {%if section.settings.button_type == "outline" %} button--secondary {% endif %} body-text-small small-body-text-small">{{ section.settings.link_text }}</a>
                  {%  endif %}
                  </div>
              </div>
          {% endif %}
        {%  endif %}

    </div>

</section>

{% schema %}
{
  "name": "Hero Banner",
  "class": "index-section--hero",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_tranprent_header",
      "label": "Enable Transprent Header"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color_background",
      "id": "button_background_color",
      "label": "Background Color",
