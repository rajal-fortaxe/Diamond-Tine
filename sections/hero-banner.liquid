      "visible_if": "{{section.settings.button_type == 'solid'}}",
    },
    {
      "type": "checkbox",
      "id": "ebable_spacing",
      "label": "Enable Spacing"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
